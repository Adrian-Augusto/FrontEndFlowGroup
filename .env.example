# ============================================================
# VARIÁVEIS DE AMBIENTE - Template
# ============================================================
# Copie este arquivo para .env e configure com seus valores

# Frontend - API Configuration
VITE_API_URL=/api/v1
VITE_API_ORIGIN=https://allgrops.onrender.com
VITE_PROXY_TARGET=https://allgrops.onrender.com
VITE_AUTH_GOOGLE_URL=https://allgrops.onrender.com/api/v1/auth/google
VITE_AUTH_REDIRECT_PARAM=redirect

# Frontend - Features
VITE_USE_MOCK=false
VITE_AUTH_STORAGE=sessionStorage

# Backend - Server Configuration
PORT=8080
NODE_ENV=production
CLIENT_ORIGIN=http://localhost:5173,https://front-end-flow-group.vercel.app
SERVER_ORIGIN=https://allgrops.onrender.com
ADMIN_EMAILS=admin@example.com,demo@gmail.com

# ============================================================
# DESENVOLVIMENTO LOCAL (.env.local)
# ============================================================
# Descomente as linhas abaixo em .env.local para usar localhost:
# VITE_API_ORIGIN=
# VITE_PROXY_TARGET=http://localhost:8080
# VITE_AUTH_GOOGLE_URL=http://localhost:8080/api/v1/auth/google
# NODE_ENV=development
